{
  "name": "clinica-altamente",
  "version": "0.1.0",
  "description": "Sistema de gestão para clínica médica",
  "author": {
    "name": "Atuã Pinali Doederlein",
    "email": "atua@github.com"
  },
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ataua/clinica-altamente"
  },
  "scripts": {
    "dev": "bun --bun next dev --webpack",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "eslint .",
    "test": "bunx dotenv -e .env.test -- bun run test:setup && bun test",
    "test:coverage": "bunx dotenv -e .env.test -- bun run test:setup && bun test --coverage",
    "test:setup": "bunx prisma db push",
    "test:clean": "docker stop clinica-altamente-db-test && docker rm clinica-altamente-db-test",
    "db:generate": "bunx prisma generate",
    "db:push": "bunx prisma db push",
    "db:studio": "bunx prisma studio",
    "db:migrate": "bunx prisma migrate dev"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/nodemailer": "^7.0.11",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^8.0.3",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "puppeteer": "^24.40.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "bun-types": "^1.3.10",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "funding": "Projeto desenvolvido para o curso de Sistemas de Informação da Faculdade XPE em 2026",
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
