# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/clinica-altamente?schema=public"

# Authentication (generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-key-here"

# NextAuth URL (your application URL)
NEXTAUTH_URL="http://localhost:3000"

# SMTP Email Configuration (for sending notifications)
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_FROM="Clínica Altamente <noreply@clinicaaltamente.com>"

# Clinic Information
CLINIC_NAME="Clínica Altamente"
CLINIC_PHONE="(00) 00000-0000"
CLINIC_ADDRESS="Rua Exemplo, 123 - Cidade/UF"

# Environment
NODE_ENV="development"
